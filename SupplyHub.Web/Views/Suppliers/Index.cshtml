@model IEnumerable<SupplyHub.Web.Models.Supplier>

@{
    ViewData["Title"] = UiTexts.Index;
}

<div class="container pb-3">
    <h1>@UiTexts.Suppliers</h1>
</div>

<div class="container p-2 my-2">
    <a asp-action="Create" class="btn btn-outline-primary">@UiTexts.NewSupplier</a>
</div>

<div class="input-group mb-3">
    <div class="input-group-prepend">
        <span class="input-group-text" id="basic-addon1"><i class="fa fa-light fa-magnifying-glass fa-2x"></i></span>
    </div>
    <input type="text" id="supplierSearch" class="form-control" placeholder="@UiTexts.SearchSupplierPlaceholder" aria-label="Search supplier" aria-describedby="basic-addon1" />
</div>

<div class="container pt-2 bg-light ">
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Email)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Phone)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Email)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Phone)
                    </td>
                    <td class="text-end">
                        <a asp-action="Edit" asp-route-id="@item.Id">@UiTexts.Edit</a> |
                        <a asp-action="Details" asp-route-id="@item.Id">@UiTexts.Details</a> |
                        <button class="btn btn-danger btn-sm delete-btn"
                                data-id="@item.Id"
                                data-name="@item.Name"
                                data-bs-toggle="modal"
                                data-bs-target="#deleteModal">
                            @UiTexts.Delete
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div id="noResultsMessage" class="alert alert-warning mt-3" style="display: none;">
    @UiTexts.NoSuppliersFound
</div>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">@UiTexts.ConfirmDeletion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <p id="deleteMessage"></p>
            </div>

            <div class="modal-footer">
                <form id="deleteForm" asp-action="Delete">
                    <input type="hidden" name="id" id="deleteSupplierId" />
                    <button type="submit" class="btn btn-danger">@UiTexts.Delete</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">@UiTexts.Cancel</button>
                </form>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#supplierSearch').on('keyup', function () {
                var value = $(this).val().toLowerCase();
                $('tbody tr').filter(function () {
                    var text = $(this).find("td:first").text().toLowerCase();
                    $(this).toggle(text.indexOf(value) > -1)
                });

                if ($('tbody tr:visible').length === 0) {
                    $("#noResultsMessage").show();
                } else {
                    $('#noResultsMessage').hide();
                };
            });
        });
    </script>

    <script>
        $(document).ready(function () {
            $('.delete-btn').on('click', function () {
                var supplierId = $(this).data('id');
                var supplierName = $(this).data('name');
                $('#deleteMessage').text(`Are you sure you want to delete the supplier "${supplierName}"?`);
                $('#deleteSupplierId').val(supplierId);
            });
        });
    </script>
}
