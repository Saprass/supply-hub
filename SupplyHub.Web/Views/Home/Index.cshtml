@{
    ViewData["Title"] = "Home Page";
}

<div class="container">
    <div class="mb-4">
        <h1 class="display-6 fw-semibold">SupplyHub</h1>
        <p class="text-muted mb-0">
            Inventory and stock management demo built with ASP.NET Core MVC
        </p>
    </div>

    <div class="row g-4">

        <div class="col-md-6 col-xl-3">
            <!--<div class="card mb-4 box-shadow">-->
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary fs-3">
						<i class="fa-solid fa-tags"></i>
                    </div>
                    <h5 class="card-title">Categories</h5>
                    <p class="card-text text-muted flex-grow-1">Create and mantain product categories</p>
                    @* <div class="d-flex justify-content-between align-items-center">
                        <div class="btn-group">
                            <a asp-controller="Categories" asp-action="Index" class="btn btn-sm btn-outline-secondary">Go to categories</a>
                        </div>
                    </div> *@
                    <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-primary">
						Go to categories
                    </a>
                </div>
		    </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary fs-3">
                        <i class="fa-solid fa-box"></i>
                    </div>
                    <h5 class="card-title">Products</h5>
                    <p class="card-text text-muted flex-grow-1">
                        View and edit product information and stock.
                    </p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary">
                        Go to products
                    </a>
                </div>
            </div>
        </div>


        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary fs-3">
                        <i class="fa-solid fa-truck"></i>
                    </div>
                    <h5 class="card-title">Suppliers</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Store and update supplier contact information.
                    </p>
                    <a asp-controller="Suppliers" asp-action="Index" class="btn btn-outline-primary">
                        Go to suppliers
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary fs-3">
                        <i class="fa-solid fa-arrow-right-arrow-left"></i>
                    </div>
                    <h5 class="card-title">Stock Movements</h5>
                    <p class="card-text text-muted flex-grow-1">
                        Track incoming and outgoing stock movements.
                    </p>
                    <a asp-controller="StockMovements" asp-action="Index" class="btn btn-outline-primary">
                        Go to movements
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
