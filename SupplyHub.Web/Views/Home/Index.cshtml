@{
    ViewData["Title"] = UiTexts.HomeTitle;
}

<div class="container">
    <div class="mb-4">
        <h1 class="display-6 fw-semibold">@UiTexts.AppName</h1>
        <p class="text-muted mb-0">
            @UiTexts.AppDescription
        </p>
    </div>

    <div class="row g-4">

        <div class="col-md-6 col-xl-3">
            <!--<div class="card mb-4 box-shadow">-->
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary fs-3">
						<i class="fa-solid fa-tags"></i>
                    </div>
                    <h5 class="card-title">@UiTexts.Categories</h5>
                    <p class="card-text text-muted flex-grow-1">
						@UiTexts.CategoriesCardDescription
                    </p>
                    @* <div class="d-flex justify-content-between align-items-center">
                        <div class="btn-group">
                            <a asp-controller="Categories" asp-action="Index" class="btn btn-sm btn-outline-secondary">Go to categories</a>
                        </div>
                    </div> *@
                    <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-primary">
						@UiTexts.CategoriesCardButtonText
                    </a>
                </div>
		    </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary fs-3">
                        <i class="fa-solid fa-box"></i>
                    </div>
                    <h5 class="card-title">@UiTexts.Products</h5>
                    <p class="card-text text-muted flex-grow-1">
                        @UiTexts.ProductsCardDescription
                    </p>
                    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-primary">
						@UiTexts.ProductsCardButtonText
                    </a>
                </div>
            </div>
        </div>


        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary fs-3">
                        <i class="fa-solid fa-truck"></i>
                    </div>
                    <h5 class="card-title">@UiTexts.Suppliers</h5>
                    <p class="card-text text-muted flex-grow-1">
						@UiTexts.SuppliersCardDescription
                    </p>
                    <a asp-controller="Suppliers" asp-action="Index" class="btn btn-outline-primary">
						@UiTexts.SuppliersCardButtonText
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="card shadow-sm h-100 border-0">
                <div class="card-body d-flex flex-column">
                    <div class="mb-3 text-primary fs-3">
                        <i class="fa-solid fa-arrow-right-arrow-left"></i>
                    </div>
                    <h5 class="card-title">@UiTexts.StockMovements</h5>
                    <p class="card-text text-muted flex-grow-1">
                        @UiTexts.StockMovementsCardDescription
                    </p>
                    <a asp-controller="StockMovements" asp-action="Index" class="btn btn-outline-primary">
						@UiTexts.StockMovementsCardButtonText
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
